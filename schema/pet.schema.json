{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Woofbook pet entry",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "contributor", "image"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Unique slug, e.g. jane-max"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 60
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    },
    "contributor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 60,
      "description": "GitHub username or display name"
    },
    "image": {
      "type": "string",
      "pattern": "^pets/images/[a-z0-9]+(?:-[a-z0-9]+)*\\.(jpg|jpeg|png|webp)$"
    }
  }
}
